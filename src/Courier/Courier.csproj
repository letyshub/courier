<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Courier</RootNamespace>
    <AssemblyName>Courier</AssemblyName>

    <!-- NuGet metadata -->
    <PackageId>Courier.CQRS</PackageId>
    <Version>1.0.0</Version>
    <Authors>marcinnajder</Authors>
    <Description>A lightweight CQRS mediator library for .NET — dispatch commands, queries and events through a clean pipeline.</Description>
    <PackageTags>cqrs;mediator;commands;queries;events;dotnet</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/marcinnajder/simple-dotnet-cqrs</PackageProjectUrl>
    <RepositoryUrl>https://github.com/marcinnajder/simple-dotnet-cqrs</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.0" />
  </ItemGroup>

</Project>
